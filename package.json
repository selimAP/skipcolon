{
  "name": "skipcolon",
  "displayName": "skipColon",
  "description": "Skip semicolons after accepting CSS suggestions by moving the cursor past them automatically.",
  "version": "0.0.4",
  "publisher": "selimAP",
  "license": "MIT",
  "homepage": "https://github.com/selimAP/skipcolon",
  "repository": {
    "type": "git",
    "url": "https://github.com/selimAP/skipcolon.git"
  },
  "bugs": {
    "url": "https://github.com/selimAP/skipcolon/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "css",
    "scss",
    "less",
    "semicolon",
    "cursor",
    "intellisense",
    "autocomplete"
  ],
  "icon": "images/skipcolon_logo.png",
  "galleryBanner": {
    "color": "#F6F4F0",
    "theme": "light"
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:less",
    "onCommand:skipcolon.acceptSuggestionAndSkipSemicolon"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skipcolon.acceptSuggestionAndSkipSemicolon",
        "title": "Accept suggestion and skip semicolon (CSS)"
      }
    ],
    "keybindings": [
      {
        "key": "enter",
        "command": "skipcolon.acceptSuggestionAndSkipSemicolon",
        "when": "suggestWidgetVisible && editorTextFocus && (editorLangId == css || editorLangId == scss || editorLangId == less)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}